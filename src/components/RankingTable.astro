---
import EmptyRanking from "./EmptyRanking.astro";
import GameProductBadges from "./GameProductBadges.astro";
import CardGameBadges from "./CardGameBadges.astro";
import { getItemUrl, sortByRank, typeDefinitions } from "../lib/ranking";
import { getGameFilterKeys } from "../lib/game-classifier.mjs";
import { cardGameFranchiseDefinitions, getCardGameFilterKeys } from "../lib/card-game-classifier.mjs";

const {
  items = [],
  limit = 5,
  categoryFallback = "文具・雑貨",
  showPlatform = false,
  showGameClassification = false,
  showCardClassification = false,
  enableGameFilters = false,
  enableCardFilters = false,
  id = "ranking-table"
} = Astro.props;
const sortedItems = sortByRank(items);
const filterMode = enableGameFilters ? "game" : enableCardFilters ? "card" : "";
const filterDefinitions = enableGameFilters ? typeDefinitions : cardGameFranchiseDefinitions;
const filterQueryParam = enableGameFilters ? "type" : "card";
const filterDimensionLabel = enableGameFilters ? "ゲーム商品の種類" : "カードゲーム作品";
const displayItems = filterMode ? sortedItems : sortedItems.slice(0, limit);
const formatPrice = (price: number | string | undefined) => {
  const numericPrice = Number(price);
  return Number.isFinite(numericPrice) && numericPrice > 0
    ? `¥${numericPrice.toLocaleString()}`
    : "販売ページで確認";
};
const formatCategory = (item: any) => {
  if (showPlatform && item.platformLabel) {
    return showGameClassification
      ? item.platformLabel
      : [item.platformLabel, item.itemTypeLabel].filter(Boolean).join(" / ");
  }

  return item.category || item.itemTypeLabel || categoryFallback;
};
const formatDelta = (item: any) => {
  if (!item.previousComparisonReady && !item.previousRank && !item.isNew) {
    return { label: "—", className: "same" };
  }
  if (item.isNew) return { label: "NEW", className: "new" };
  const delta = Number(item.delta || 0);
  if (delta > 0) return { label: `↑ ${delta}`, className: "up" };
  if (delta < 0) return { label: `↓ ${Math.abs(delta)}`, className: "down" };
  return { label: "→ 0", className: "same" };
};
---
{sortedItems.length === 0 ? <EmptyRanking /> : (
  <div
    class:list={{ "ranking-browser": Boolean(filterMode) }}
    id={id}
    data-ranking-browser={filterMode || undefined}
    data-filter-query-param={filterQueryParam}
    data-limit={limit}
  >
    {filterMode && (
      <div class="game-type-controls" aria-label={`${filterDimensionLabel}で絞り込む`}>
        <button type="button" data-ranking-filter="all" aria-pressed="true">すべて</button>
        {filterDefinitions.map((definition) => (
          <button type="button" data-ranking-filter={definition.key} aria-pressed="false">
            {definition.label}
          </button>
        ))}
      </div>
    )}
    {filterMode && <p class="game-type-status" data-ranking-filter-status aria-live="polite"></p>}
    <div class="ranking-table">
    <div class="ranking-head">
      <span>順位</span><span>前回比</span><span>商品名</span><span>カテゴリ</span><span>価格</span><span>レビュー</span><span></span>
    </div>
    {displayItems.map((item: any, index: number) => {
      const delta = formatDelta(item);
      return (
        <article
          class="ranking-row"
          data-ranking-filter-row={filterMode ? "true" : undefined}
          data-ranking-filters={filterMode === "game"
            ? getGameFilterKeys(item).join(" ")
            : filterMode === "card"
              ? getCardGameFilterKeys(item).join(" ")
              : undefined}
          hidden={Boolean(filterMode) && index >= limit}
        >
          <strong class="rank">{item.rank}</strong>
          <span class:list={["delta", delta.className]}>{delta.label}</span>
          <div class="product-name">
            {item.image && <img src={item.image} alt="" loading="lazy" />}
            <div>
              <strong>{item.name}</strong>
              {showGameClassification && <GameProductBadges item={item} />}
              {showCardClassification && <CardGameBadges item={item} />}
              <button
                class="watch-button"
                type="button"
                aria-label={`${item.name}を気になる商品に保存`}
                data-watch-button
                data-watch-key={`${item.sourceKey}:${item.code}`}
                data-watch-source={item.sourceKey}
                data-watch-code={item.code}
                data-watch-name={item.name}
                data-watch-rank={item.rank}
                data-watch-price={item.price}
              >☆ 保存</button>
            </div>
          </div>
          <span>{formatCategory(item)}</span>
          <div class="price-detail">
            <strong class="price">{formatPrice(item.price)}</strong>
            {Number(item.priceChange || 0) < 0 && (
              <small>前回比 {formatPrice(Math.abs(Number(item.priceChange)))}値下がり</small>
            )}
          </div>
          <span>{item.reviewAverage || "—"}（{Number(item.reviewCount || 0).toLocaleString()}件）</span>
          <a class="item-link" href={getItemUrl(item)} target="_blank" rel="nofollow sponsored noopener">商品を見る</a>
        </article>
      );
    })}
    </div>
  </div>
)}

{filterMode && (
  <script is:inline>
    document.querySelectorAll('[data-ranking-browser]').forEach((browser) => {
      if (browser.dataset.initialized === "true") return;
      browser.dataset.initialized = "true";
      const buttons = [...browser.querySelectorAll("[data-ranking-filter]")];
      const rows = [...browser.querySelectorAll("[data-ranking-filter-row]")];
      const status = browser.querySelector("[data-ranking-filter-status]");
      const limit = Number(browser.dataset.limit || 20);
      const queryParam = browser.dataset.filterQueryParam || "type";
      const requested = new URLSearchParams(window.location.search).get(queryParam);
      let active = buttons.some((button) => button.dataset.rankingFilter === requested)
        ? requested
        : "all";

      const render = () => {
        let visible = 0;
        rows.forEach((row) => {
          const matches = active === "all" ||
            (row.dataset.rankingFilters || "").split(" ").includes(active);
          const show = matches && visible < limit;
          row.hidden = !show;
          if (show) visible += 1;
        });
        buttons.forEach((button) => {
          button.setAttribute("aria-pressed", String(button.dataset.rankingFilter === active));
        });
        const label = buttons.find((button) => button.dataset.rankingFilter === active)?.textContent?.trim() || "すべて";
        if (status) status.textContent = `${label}：${visible}件を表示`;
      };

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          active = button.dataset.rankingFilter || "all";
          const url = new URL(window.location.href);
          if (active === "all") url.searchParams.delete(queryParam);
          else url.searchParams.set(queryParam, active);
          history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
          render();
        });
      });
      render();
    });
  </script>
)}
