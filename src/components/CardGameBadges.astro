---
import type { RankingItem } from "../lib/ranking";

interface Props {
  item: RankingItem;
}

const { item } = Astro.props;
const badges = [
  item.cardFranchiseLabel || "その他",
  item.cardProductTypeLabel || "カードゲーム商品",
  ...(Array.isArray(item.cardAttributeLabels) ? item.cardAttributeLabels : [])
].filter((label, index, values) => label && values.indexOf(label) === index);
---
<span class="card-product-badges" aria-label="作品・商品の種類・状態">
  {badges.map((label, index) => (
    <span class:list={{ "card-product-badge": true, "is-attribute": index > 1 }}>{label}</span>
  ))}
</span>
