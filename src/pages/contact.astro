---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config";
---
<BaseLayout title="お問い合わせ｜モノ上昇便">
  <article class="legal-page">
    <h1>お問い合わせ</h1>
    {siteConfig.xUrl ? <p>Xアカウントからお問い合わせください。</p> : <p>Xアカウントの設定準備中です。確定後、こちらにお問い合わせ先を掲載します。</p>}
    {siteConfig.xUrl && <a class="contact-button inline" href={siteConfig.xUrl} target="_blank" rel="noopener">Xを開く</a>}
  </article>
</BaseLayout>
