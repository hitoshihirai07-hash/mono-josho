---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChangeBoard from "../components/ChangeBoard.astro";
import GameRankingNotice from "../components/GameRankingNotice.astro";
import TodayHighlights from "../components/TodayHighlights.astro";
import WatchlistPanel from "../components/WatchlistPanel.astro";
import WeeklyAccessoryPicks from "../components/WeeklyAccessoryPicks.astro";
import ranking from "../data/ranking.json";
import editorial from "../data/editorial.json";
import { getHomeCategories } from "../lib/categories";
import {
  createItemListSchema,
  formatUpdated,
  getCardGameItems,
  gameSourceDefinitions,
  getEnabledCategoryItems,
  getPlatformRankingItems,
  getStationeryItems,
  hasMeaningfulChanges,
  typeDefinitions
} from "../lib/ranking";
import { isWeeklyEditorialPublishable } from "../../scripts/lib/editorial.mjs";

const updated = formatUpdated(ranking.updatedAt, "未取得");
const allEnabledItems = getEnabledCategoryItems(ranking);
const platformItems = getPlatformRankingItems(ranking);
const cardGameItems = getCardGameItems(ranking);
const stationeryItems = getStationeryItems(ranking);
const weekly = editorial.gameWeekly;
const showWeekly = isWeeklyEditorialPublishable(weekly);
const showCardGameChanges = hasMeaningfulChanges(cardGameItems, "day");
const showStationeryChanges = hasMeaningfulChanges(stationeryItems, "day");
const pageUrl = new URL("/", Astro.site).toString();
const homeCategories = getHomeCategories();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "楽天ランキングの順位変動をカテゴリ別に確認",
    description: "ゲームを中心に、カードゲームと文具を含む楽天市場ランキングの新登場・順位上昇・値下がりをカテゴリ別に確認できます。",
    url: pageUrl,
    inLanguage: "ja",
    isPartOf: { "@id": new URL("/#website", Astro.site).toString() }
  },
  allEnabledItems.length > 0 ? createItemListSchema(allEnabledItems, pageUrl) : null
].filter(Boolean);

const platformLinks = gameSourceDefinitions.filter((source) =>
  ["switch", "ps5", "ps4"].includes(source.key)
);
---
<BaseLayout
  title="楽天ランキングの順位変動｜ゲーム・カードゲーム・文具｜モノ上昇便"
  description="楽天市場のランキング順位変動をカテゴリ別に確認できます。ゲームを中心に、カードゲームと文具の新登場・順位上昇・値下がりを掲載します。"
  structuredData={structuredData}
>
  <section class="hero game-first-hero">
    <div class="hero-content">
      <h1>楽天ランキングの<span>順位変動</span>を、カテゴリ別に。</h1>
      <p>ゲームを中心に、カードゲームと文具の新登場・順位上昇・値下がりを24時間前と比較します。</p>
    </div>
    <p class="updated"><span>最終更新</span>{updated}</p>
  </section>

  <TodayHighlights items={allEnabledItems} updatedAt={ranking.updatedAt} />

  <WeeklyAccessoryPicks ranking={ranking} />

  <section class="home-game-changes" aria-labelledby="home-game-changes-title">
    <header class="home-section-heading">
      <span>GAME</span>
      <h2 id="home-game-changes-title">ゲームの注目変動</h2>
      <p>Switch・PS5・PS4のランキングを混ぜずに、24時間の変化を確認します。</p>
    </header>
    <ChangeBoard
      items={platformItems}
      id="home-ranking-changes"
      title="24時間の変化"
      comparisonWindow="day"
      persistSource={true}
      showGameClassification={true}
    />
    <GameRankingNotice />
    {showWeekly && (
      <a class="weekly-inline-link" href="/articles/current-game-ranking/">
        <span>{weekly.periodLabel}</span>
        <strong>{weekly.headline}</strong>
        <b>週次まとめを見る →</b>
      </a>
    )}
  </section>

  <section class="platform-entry game-route-entry" aria-labelledby="game-route-entry-title">
    <header>
      <h2 id="game-route-entry-title">ゲームを機種・種類から見る</h2>
      <p>機種別の取得元と、商品名から判定できた種類で絞り込めます。</p>
    </header>
    <div>
      {platformLinks.map((source) => (
        <a href={source.href}>
          <span>{source.shortLabel}</span>
          <strong>{source.shortLabel}ランキング</strong>
          <b aria-hidden="true">→</b>
        </a>
      ))}
    </div>
    <nav class="game-type-links" aria-label="ゲーム商品の種類">
      {typeDefinitions.map((type) => (
        <a href={`/games/?type=${type.key}#game-type-ranking`}>{type.label}</a>
      ))}
    </nav>
  </section>

  <section class="other-category-changes card-game-category-changes" aria-labelledby="card-game-category-changes-title">
    <header class="home-section-heading">
      <span>CARD GAME</span>
      <h2 id="card-game-category-changes-title">カードゲームの注目変動</h2>
      <p>ポケモンカード、遊戯王などを含むカードゲーム総合ランキングを確認できます。</p>
    </header>
    {showCardGameChanges ? (
      <ChangeBoard
        items={cardGameItems}
        id="card-game-ranking-changes-home"
        title="24時間の変化"
        comparisonWindow="day"
        showSourceFilters={false}
        showCardClassification={true}
        dimensionLabel="作品"
        defaultSourceLabel="カードゲーム"
        moreHref="/categories/card-games/"
        moreLabel="カードゲームランキングを見る →"
      />
    ) : (
      <a class="category-focus-link" href="/categories/card-games/">
        <strong>カードゲームランキングを見る</strong>
        <span>現在順位と、取得後の新登場・順位上昇・値下がりを確認できます。</span>
        <b>ポケモンカードなどを作品別に見る →</b>
      </a>
    )}
  </section>

  {showStationeryChanges && (
    <section class="other-category-changes" aria-labelledby="other-category-changes-title">
      <header class="home-section-heading">
        <span>OTHER</span>
        <h2 id="other-category-changes-title">その他のカテゴリの注目変動</h2>
      </header>
      <ChangeBoard
        items={stationeryItems}
        id="other-ranking-changes"
        title="24時間の変化"
        comparisonWindow="day"
        showSourceFilters={false}
        dimensionLabel="カテゴリ"
        defaultSourceLabel="文具"
        moreHref="/categories/stationery/"
        moreLabel="文具ランキングを見る →"
      />
    </section>
  )}

  <section class="category-directory" aria-labelledby="category-directory-title">
    <header class="home-section-heading">
      <span>CATEGORY</span>
      <h2 id="category-directory-title">公開中のカテゴリ</h2>
      <p>カテゴリごとに、現在順位と直近の変化を確認できます。</p>
    </header>
    <div>
      {homeCategories.map((category) => (
        <a href={category.route || "/"}>
          <strong>{category.displayName}</strong>
          <span>{category.description}</span>
          <b>ランキングを見る →</b>
        </a>
      ))}
    </div>
  </section>

  <WatchlistPanel items={allEnabledItems} />
</BaseLayout>
