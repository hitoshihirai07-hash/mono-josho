---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChangeBoard from "../components/ChangeBoard.astro";
import TodayHighlights from "../components/TodayHighlights.astro";
import WatchlistPanel from "../components/WatchlistPanel.astro";
import ranking from "../data/ranking.json";
import editorial from "../data/editorial.json";
import {
  createItemListSchema,
  formatPublishedDate,
  formatUpdated,
  gameSourceDefinitions,
  getGameItems,
  getPlatformRankingItems
} from "../lib/ranking";

const updated = formatUpdated(ranking.updatedAt, "更新準備中");
const gameItems = getGameItems(ranking);
const platformItems = getPlatformRankingItems(ranking);
const weekly = editorial.gameWeekly;
const weeklyUpdated = formatPublishedDate(weekly.updatedAt, "比較準備中");
const pageUrl = new URL("/", Astro.site).toString();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "今日のゲームランキング｜Switch・PS5・PS4の変化",
    description: "Nintendo Switch、PS5、PS4のランキングを分け、新登場・急上昇・値下がりを前回更新と比較します。",
    url: pageUrl,
    inLanguage: "ja",
    isPartOf: { "@id": new URL("/#website", Astro.site).toString() }
  },
  gameItems.length > 0 ? createItemListSchema(gameItems, pageUrl) : null
].filter(Boolean);

const platformLinks = gameSourceDefinitions.filter((source) =>
  ["switch", "ps5", "ps4"].includes(source.key)
);
---
<BaseLayout
  title="今日のゲームランキング｜Switch・PS5・PS4の変化｜モノ上昇便"
  description="Switch・PS5・PS4を別ランキングで比較。新登場・急上昇・値下がりを前回更新から追えるゲームランキング情報です。"
  structuredData={structuredData}
>
  <section class="hero game-first-hero">
    <div class="hero-content">
      <h1>今日のゲームランキング、<span>変わったところだけ。</span></h1>
      <p>Switch・PS5・PS4を別ランキングで比較。新登場・急上昇・値下がりを前回更新から追えます。</p>
    </div>
    <p class="updated"><span>最終更新</span>{updated}</p>
  </section>

  <WatchlistPanel items={platformItems} />
  <TodayHighlights items={platformItems} updatedAt={ranking.updatedAt} />

  <div class="change-editorial-layout">
    <ChangeBoard
      items={platformItems}
      id="home-ranking-changes"
      title="24時間の変化"
      comparisonWindow="day"
      persistSource={true}
    />
    <aside class="weekly-note" aria-labelledby="weekly-note-title">
      <header><h2 id="weekly-note-title">今週の注目</h2></header>
      <div>
        <h3>{weekly.headline}</h3>
        <p>{weekly.summary}</p>
        {weekly.points?.length > 0 ? <ol>
          {weekly.points.slice(0, 3).map((point) => (
            <li>
              <strong>{point.title}</strong>
              <span>{point.body}</span>
            </li>
          ))}
        </ol> : <p class="weekly-waiting">7日間の比較データを準備中です。</p>}
        <p class="weekly-disclosure">{weekly.dataDisclosure}</p>
        <p class="weekly-signature">{weeklyUpdated}更新　{weekly.authorName}</p>
        <a href="/articles/current-game-ranking/">今週のまとめを読む →</a>
      </div>
    </aside>
  </div>

  <section class="platform-entry" aria-labelledby="platform-entry-title">
    <header>
      <h2 id="platform-entry-title">機種別ランキング</h2>
      <p>総合順位から抜き出さず、機種ごとの取得元をそのまま表示します。</p>
    </header>
    <div>
      {platformLinks.map((source) => (
        <a href={source.href}>
          <span>{source.shortLabel}</span>
          <strong>{source.shortLabel}ランキングを見る</strong>
          <b aria-hidden="true">→</b>
        </a>
      ))}
    </div>
  </section>

  <section class="stationery-entry" aria-labelledby="stationery-entry-title">
    <h2 id="stationery-entry-title">文具も見る</h2>
    <a href="/categories/stationery/">
      <span>文具・シールのランキング、新登場、順位変動を確認できます。</span>
      <strong>文具ランキングを見る →</strong>
    </a>
  </section>
</BaseLayout>
