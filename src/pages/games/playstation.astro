---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ChangeBoard from "../../components/ChangeBoard.astro";
import GameRankingNotice from "../../components/GameRankingNotice.astro";
import RankingTable from "../../components/RankingTable.astro";
import ranking from "../../data/ranking.json";
import { createItemListSchema, formatPublishedDate, getGameSourceItems, getTypeGroups } from "../../lib/ranking";

const ps5Items = getGameSourceItems(ranking, "ps5");
const ps4Items = getGameSourceItems(ranking, "ps4");
const items = [...ps5Items, ...ps4Items];
const typeGroups = getTypeGroups(items);
const published = formatPublishedDate(ranking.updatedAt);
const pageUrl = new URL("/games/playstation/", Astro.site).toString();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "ホーム", item: new URL("/", Astro.site).toString() },
      { "@type": "ListItem", position: 2, name: "ゲーム", item: new URL("/games/", Astro.site).toString() },
      { "@type": "ListItem", position: 3, name: "PlayStationランキング", item: pageUrl }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "PlayStation関連ランキング",
    description: "楽天のPS5ジャンルとPS4ジャンルのランキングを混ぜずに整理します。",
    url: pageUrl
  },
  items.length > 0 ? createItemListSchema(items, pageUrl) : null
].filter(Boolean);
---
<BaseLayout
  title="PS5・PS4ランキングの順位変動｜種類・中古・予約も確認｜モノ上昇便"
  description="楽天市場のPS5ランキングとPS4ランキングの順位変動を別々に掲載。ソフト、本体、周辺機器、中古、輸入版、予約商品の区別も確認できます。"
  structuredData={structuredData}
>
  <article class="article-page game-page">
    <header>
      <p class="breadcrumbs"><a href="/">ホーム</a> › <a href="/games/">ゲーム</a> › PlayStation</p>
      <h1>PS5・PS4<br /><span>機種別ランキング</span></h1>
      <p>楽天のPS5ジャンル、PS4ジャンルから別々に取得します。世代の異なる商品を混ぜて1つの順位にはしません。</p>
      <div class="article-meta">{published}更新　｜　楽天市場ランキングを基に掲載</div>
    </header>
    <section class="platform-section" id="ps5-ranking">
      <header>
        <h2><span>01</span>PlayStation 5ランキング</h2>
        <p>楽天のプレイステーション5ジャンルから取得します。</p>
      </header>
      <ChangeBoard
        items={ps5Items}
        id="ps5-ranking-changes"
        showSourceFilters={false}
        moreHref="#ps5-products"
        title="前回更新からの変化"
        headingLevel={3}
        showGameClassification={true}
      />
      <div id="ps5-products">
      <RankingTable items={ps5Items} limit={10} showPlatform={true} showGameClassification={true} categoryFallback="PlayStation 5" />
      </div>
      <GameRankingNotice />
    </section>
    <section class="platform-section" id="ps4-ranking">
      <header>
        <h2><span>02</span>PlayStation 4ランキング</h2>
        <p>楽天のプレイステーション4ジャンルから取得します。</p>
      </header>
      <ChangeBoard
        items={ps4Items}
        id="ps4-ranking-changes"
        showSourceFilters={false}
        moreHref="#ps4-products"
        title="前回更新からの変化"
        headingLevel={3}
        showGameClassification={true}
      />
      <div id="ps4-products">
      <RankingTable items={ps4Items} limit={10} showPlatform={true} showGameClassification={true} categoryFallback="PlayStation 4" />
      </div>
      <GameRankingNotice />
    </section>
    <section class="seo-block">
      <h2><span>03</span>種類別の内訳</h2>
      <div class="type-grid">
        {typeGroups.map((group) => (
          <div>
            <strong>{group.label}</strong>
            <span>{group.items.length}件</span>
            <p>{group.description}</p>
          </div>
        ))}
      </div>
      <p>種類や状態の表示は商品名などから明確に判定できる場合に限り、判断できない商品は「その他」としています。</p>
      <p>取得元や更新方法は<a href="/about/">運営情報</a>で公開しています。</p>
    </section>
    <aside class="notice"><strong>続けて確認する</strong><p><a href="/games/switch/">Switchランキング</a>、または<a href="/games/">ゲーム全体の順位変動</a>を確認できます。</p></aside>
  </article>
</BaseLayout>
