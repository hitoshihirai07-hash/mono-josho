---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RankingTable from "../../components/RankingTable.astro";
import ranking from "../../data/ranking.json";
import {
  createItemListSchema,
  formatPublishedDate,
  getGameItems,
  getPlatformGroups,
  getTypeGroups
} from "../../lib/ranking";

const gameItems = getGameItems(ranking);
const platformGroups = getPlatformGroups(gameItems);
const typeGroups = getTypeGroups(gameItems);
const published = formatPublishedDate(ranking.updatedAt);
const pageUrl = new URL("/games/", Astro.site).toString();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "ホーム", item: new URL("/", Astro.site).toString() },
      { "@type": "ListItem", position: 2, name: "ゲームランキング", item: pageUrl }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "ゲームランキング",
    description: "楽天市場のゲームランキングをSwitch、PlayStation、ソフト、本体、周辺機器別に整理します。",
    url: pageUrl
  },
  gameItems.length > 0 ? createItemListSchema(gameItems, pageUrl) : null
].filter(Boolean);
---
<BaseLayout
  title="ゲームランキング｜Switch・PlayStation別に探す｜モノ上昇便"
  description="楽天市場のゲームランキングを、Switch・PlayStation・その他、ソフト・本体・周辺機器別に整理します。"
  structuredData={structuredData}
>
  <article class="article-page game-page">
    <header>
      <p class="breadcrumbs"><a href="/">ホーム</a> › ゲーム</p>
      <h1>ゲームランキングを<br /><span>機種別</span>に探す</h1>
      <p>テレビゲームのランキングを、Switch / PlayStation / その他と、ソフト・本体・周辺機器に分けて見られるページです。</p>
      <div class="article-meta">{published}更新　｜　楽天市場ランキングを基に掲載</div>
    </header>

    <section>
      <h2><span>01</span>機種別の入口</h2>
      <div class="platform-grid">
        {platformGroups.map((group) => (
          <a class="platform-card" id={group.key === "other" ? "other" : undefined} href={group.href}>
            <span>{group.shortLabel}</span>
            <strong>{group.label}</strong>
            <p>{group.description}</p>
            <b>{group.items.length}件</b>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2><span>02</span>現在のゲーム上位</h2>
      <RankingTable items={gameItems} limit={10} showPlatform={true} categoryFallback="ゲーム" />
    </section>

    <section>
      <h2><span>03</span>機種ごとのランキング</h2>
      {platformGroups.map((group) => (
        <section class="platform-section" id={`${group.key}-ranking`}>
          <header>
            <h3>{group.label}</h3>
            <p>{group.items.length > 0 ? `${group.items.length}件を掲載しています。` : "データ取得後にここへ掲載します。"}</p>
          </header>
          <RankingTable items={group.items} limit={5} showPlatform={true} categoryFallback="ゲーム" />
        </section>
      ))}
    </section>

    <section class="seo-block">
      <h2><span>04</span>種類別の見方</h2>
      <div class="type-grid">
        {typeGroups.map((group) => (
          <div>
            <strong>{group.label}</strong>
            <span>{group.items.length}件</span>
            <p>{group.description}</p>
          </div>
        ))}
      </div>
      <p>同じタイトルでも、対応機種、特典、発送時期、商品状態が異なる場合があります。購入前に販売ページで最新の価格、在庫、同梱物を確認してください。</p>
    </section>
  </article>
</BaseLayout>
