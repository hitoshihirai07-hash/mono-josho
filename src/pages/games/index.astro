---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ChangeBoard from "../../components/ChangeBoard.astro";
import RankingTable from "../../components/RankingTable.astro";
import ranking from "../../data/ranking.json";
import {
  createItemListSchema,
  formatPublishedDate,
  getGameOverallItems,
  getGameItems,
  getPlatformGroups,
  getGameSourceGroups,
  getTypeGroups
} from "../../lib/ranking";

const gameItems = getGameItems(ranking);
const overallItems = getGameOverallItems(ranking);
const platformGroups = getPlatformGroups(gameItems);
const sourceGroups = getGameSourceGroups(gameItems);
const platformRankingGroups = sourceGroups.filter((group) => group.key !== "games-overall");
const typeGroups = getTypeGroups(gameItems);
const published = formatPublishedDate(ranking.updatedAt);
const pageUrl = new URL("/games/", Astro.site).toString();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "ホーム", item: new URL("/", Astro.site).toString() },
      { "@type": "ListItem", position: 2, name: "ゲームランキング", item: pageUrl }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "ゲームランキング",
    description: "楽天市場のテレビゲーム総合、Nintendo Switch、PS5、PS4の各ランキングを分けて整理します。",
    url: pageUrl
  },
  overallItems.length > 0 ? createItemListSchema(overallItems, pageUrl) : null
].filter(Boolean);
---
<BaseLayout
  title="ゲームランキング｜Switch・PS5・PS4を機種別に比較｜モノ上昇便"
  description="楽天市場のゲーム総合、Nintendo Switch、PS5、PS4ランキングを混ぜずに掲載。新登場・急上昇・値下がりも確認できます。"
  structuredData={structuredData}
>
  <article class="article-page game-page">
    <header>
      <p class="breadcrumbs"><a href="/">ホーム</a> › ゲーム</p>
      <h1>ゲームランキングを<br /><span>機種別</span>に確認</h1>
      <p>テレビゲーム総合、Nintendo Switch、PS5、PS4を別の取得元として整理し、前回更新からの変化も表示します。</p>
      <div class="article-meta">{published}更新　｜　楽天市場ランキングを基に掲載</div>
    </header>

    <section>
      <h2><span>01</span>機種別の入口</h2>
      <div class="platform-grid">
        {platformGroups.map((group) => (
          <a class="platform-card" id={group.key === "other" ? "other" : undefined} href={group.href}>
            <span>{group.shortLabel}</span>
            <strong>{group.label}</strong>
            <p>{group.description}</p>
            <b>{group.key === "playstation" ? "PS5/PS4別" : group.key === "switch" ? "Switch専用" : "総合"}</b>
          </a>
        ))}
      </div>
    </section>

    <section class="change-section">
      <ChangeBoard items={gameItems} id="game-ranking-changes" title="02 前回更新からの変化" />
    </section>

    <section id="overall-ranking">
      <h2><span>03</span>テレビゲーム総合ランキング</h2>
      <RankingTable items={overallItems} limit={10} showPlatform={true} categoryFallback="ゲーム" />
    </section>

    <section>
      <h2><span>04</span>取得元ごとの機種別ランキング</h2>
      {platformRankingGroups.map((group) => (
        <section class="platform-section" id={`${group.key}-ranking`}>
          <header>
            <h3>{group.label}</h3>
            <p>{group.description}</p>
          </header>
          <RankingTable items={group.items} limit={5} showPlatform={true} categoryFallback="ゲーム" />
        </section>
      ))}
    </section>

    <section class="seo-block">
      <h2><span>05</span>種類別の見方</h2>
      <div class="type-grid">
        {typeGroups.map((group) => (
          <div>
            <strong>{group.label}</strong>
            <span>{group.items.length}件</span>
            <p>{group.description}</p>
          </div>
        ))}
      </div>
      <p>同じタイトルでも、対応機種、特典、発送時期、商品状態が異なる場合があります。購入前に販売ページで最新の価格、在庫、同梱物を確認してください。</p>
      <p>ランキングの取得元、更新方法、広告については<a href="/about/">運営情報</a>で確認できます。</p>
    </section>
  </article>
</BaseLayout>
