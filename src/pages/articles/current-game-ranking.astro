---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RankingTable from "../../components/RankingTable.astro";
import ranking from "../../data/ranking.json";

const gameItems = ranking.items
  .filter((item: any) => item.categoryKey === "games")
  .sort((a: any, b: any) => a.rank - b.rank);
const published = ranking.updatedAt
  ? new Intl.DateTimeFormat("ja-JP", { dateStyle: "long", timeZone: "Asia/Tokyo" }).format(new Date(ranking.updatedAt))
  : "更新準備中";
---
<BaseLayout title="楽天市場で現在注目のゲーム5選｜モノ上昇便">
  <article class="article-page">
    <header>
      <p class="breadcrumbs"><a href="/">ホーム</a> › <a href="/articles/">記事一覧</a></p>
      <h1>楽天市場で現在<br /><span>注目</span>のゲーム5選</h1>
      <p>楽天市場のテレビゲームランキングから、ゲームソフト・本体・周辺機器の上位商品を整理します。</p>
      <div class="article-meta">{published}更新　｜　楽天市場ランキングを基に掲載</div>
    </header>
    <section>
      <h2><span>01</span>現在の上位5商品</h2>
      <RankingTable items={gameItems} />
    </section>
    <section>
      <h2><span>02</span>確認したいポイント</h2>
      <p>同じタイトルでも、対応機種、特典、商品状態、発送時期が異なる場合があります。ゲーム機本体では国内版・セット内容も確認してください。</p>
    </section>
    <aside class="notice"><strong>掲載情報について</strong><p>価格や在庫は変動します。購入前に販売ページで最新情報をご確認ください。</p></aside>
  </article>
</BaseLayout>
