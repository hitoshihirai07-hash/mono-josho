---
import BaseLayout from "../../layouts/BaseLayout.astro";
import editorial from "../../data/editorial.json";
import archive from "../../data/editorial-archive.json";
import { isWeeklyEditorialPublishable } from "../../../scripts/lib/editorial.mjs";

const weekly = editorial.gameWeekly;
const showCurrent = isWeeklyEditorialPublishable(weekly);
const publishedWeeks = (archive.weeks || []).filter((week) =>
  week.archiveEligible && Array.isArray(week.points) && week.points.length === 3
);
const hasArticles = showCurrent || publishedWeeks.length > 0;
---
<BaseLayout
  title="ゲームランキング変動の週次記録｜モノ上昇便"
  description="Switch・PS5・PS4のランキングで、実際に確認できた順位上昇・値下がり・新登場を週別に記録します。"
  robots={publishedWeeks.length > 0 ? "index,follow" : "noindex,follow"}
>
  <section class="page-heading">
    <h1>ランキング変動の週次記録</h1>
    <p>十分な比較データと具体的な変化が確認できた週だけ掲載します。</p>
  </section>
  <div class="article-index">
    {showCurrent && (
      <a href="/articles/current-game-ranking/">
        <time>{weekly.periodLabel}</time>
        <strong>{weekly.headline}</strong>
        <span>{weekly.summary}</span>
      </a>
    )}
    {publishedWeeks.map((week) => (
      <a href={`/articles/game-ranking/${week.weekKey}/`}>
        <time>{week.periodLabel}</time>
        <strong>{week.headline}</strong>
        <span>{week.summary}</span>
      </a>
    ))}
    {!hasArticles && (
      <p class="article-index-empty">現在公開している週次記録はありません。ランキング変動は下記のカテゴリページで確認できます。</p>
    )}
    <a href="/games/"><time>ゲーム</time><strong>ゲームランキングの順位変動を見る</strong><span>Switch、PS5、PS4と商品種類から確認できます。</span></a>
    <a href="/categories/card-games/"><time>カード</time><strong>カードゲームランキングの順位変動を見る</strong><span>ポケモンカード、遊戯王などを作品別に確認できます。</span></a>
    <a href="/categories/stationery/"><time>文具</time><strong>文具・事務用品ランキングの順位変動を見る</strong><span>現在順位と直近の変化を確認できます。</span></a>
  </div>
</BaseLayout>
