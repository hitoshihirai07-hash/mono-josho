---
import BaseLayout from "../../layouts/BaseLayout.astro";
import editorial from "../../data/editorial.json";
import archive from "../../data/editorial-archive.json";
import { isWeeklyEditorialPublishable } from "../../../scripts/lib/editorial.mjs";

const weekly = editorial.gameWeekly;
const cardWeekly = editorial.cardWeekly;
const showCurrentGame = isWeeklyEditorialPublishable(weekly);
const showCurrentCard = isWeeklyEditorialPublishable(cardWeekly);
const publishedGameWeeks = (archive.weeks || []).filter((week) =>
  week.archiveEligible && Array.isArray(week.points) && week.points.length === 3
);
const publishedCardWeeks = (archive.cardWeeks || []).filter((week) =>
  week.archiveEligible && Array.isArray(week.points) && week.points.length === 3
);
const articles = [
  ...(showCurrentGame ? [{ ...weekly, sectionLabel: "ゲーム", href: `/articles/game-ranking/${weekly.weekKey}/` }] : []),
  ...(showCurrentCard ? [{ ...cardWeekly, sectionLabel: "カードゲーム", href: `/articles/card-game-ranking/${cardWeekly.weekKey}/` }] : []),
  ...publishedGameWeeks.map((week) => ({
    ...week,
    sectionLabel: "ゲーム",
    href: `/articles/game-ranking/${week.weekKey}/`
  })),
  ...publishedCardWeeks.map((week) => ({
    ...week,
    sectionLabel: "カードゲーム",
    href: `/articles/card-game-ranking/${week.weekKey}/`
  }))
].sort((a, b) => b.weekKey.localeCompare(a.weekKey) || a.sectionLabel.localeCompare(b.sectionLabel, "ja"));
const hasArticles = articles.length > 0;
---
<BaseLayout
  title="ランキング変動の週次記録｜ゲーム・カードゲーム｜モノ上昇便"
  description="ゲームとカードゲームのランキングで、実際に確認できた順位上昇・値下がり・新登場を週別に記録します。"
  robots={hasArticles ? "index,follow" : "noindex,follow"}
>
  <section class="page-heading">
    <h1>ランキング変動の週次記録</h1>
    <p>十分な比較データと具体的な変化が確認できた週だけ掲載します。</p>
  </section>
  <div class="article-index">
    {articles.map((article) => (
      <a href={article.href}>
        <time>{article.periodLabel}・{article.sectionLabel}</time>
        <strong>{article.headline}</strong>
        <span>{article.summary}</span>
      </a>
    ))}
    {!hasArticles && (
      <p class="article-index-empty">現在公開している週次記録はありません。ランキング変動は下記のカテゴリページで確認できます。</p>
    )}
    <a href="/games/"><time>ゲーム</time><strong>ゲームランキングの順位変動を見る</strong><span>Switch、PS5、PS4と商品種類から確認できます。</span></a>
    <a href="/categories/card-games/"><time>カード</time><strong>カードゲームランキングの順位変動を見る</strong><span>ポケモンカード、遊戯王などを作品別に確認できます。</span></a>
    <a href="/categories/stationery/"><time>文具</time><strong>文具・事務用品ランキングの順位変動を見る</strong><span>現在順位と直近の変化を確認できます。</span></a>
  </div>
</BaseLayout>
