---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import archive from "../../../data/editorial-archive.json";
import { formatPublishedDate } from "../../../lib/ranking";

export function getStaticPaths() {
  return (archive.weeks || [])
    .filter((week) => week.archiveEligible && Array.isArray(week.points) && week.points.length === 3)
    .map((week) => ({
    params: { week: week.weekKey },
    props: { week }
  }));
}

const { week } = Astro.props;
const updated = formatPublishedDate(week.updatedAt, week.periodLabel);
const pageUrl = new URL(`/articles/game-ranking/${week.weekKey}/`, Astro.site).toString();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "ホーム", item: new URL("/", Astro.site).toString() },
      { "@type": "ListItem", position: 2, name: "記事一覧", item: new URL("/articles/", Astro.site).toString() },
      { "@type": "ListItem", position: 3, name: week.headline, item: pageUrl }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: week.headline,
    description: week.summary,
    datePublished: week.publishedAt,
    dateModified: week.updatedAt,
    inLanguage: "ja",
    mainEntityOfPage: pageUrl,
    author: {
      "@type": "Organization",
      name: week.authorName,
      url: new URL("/about/", Astro.site).toString()
    },
    publisher: { "@id": new URL("/#organization", Astro.site).toString() }
  }
];
---
<BaseLayout
  title={`${week.headline}｜モノ上昇便`}
  description={week.summary}
  structuredData={structuredData}
  ogType="article"
  publishedTime={week.publishedAt}
  modifiedTime={week.updatedAt}
>
  <article class="article-page weekly-article archived-weekly-article">
    <header>
      <p class="breadcrumbs"><a href="/">ホーム</a> › <a href="/articles/">記事一覧</a> › {week.weekKey}</p>
      <p class="weekly-period">{week.periodLabel}</p>
      <h1>{week.headline}</h1>
      <p>{week.summary}</p>
      <div class="article-meta">
        {updated}更新　｜　執筆：<a href="/about/">{week.authorName}</a>
      </div>
    </header>

    <section>
      <h2><span>01</span>この週に確認した3つの動き</h2>
      <div class="editorial-points">
        {week.points.map((point, index) => (
          <article>
            <span>0{index + 1}</span>
            <h3>{point.title}</h3>
            <p>{point.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section>
      <h2><span>02</span>現在の機種別ランキング</h2>
      <div class="article-route-list">
        <a href="/games/switch/"><strong>Switchランキング</strong><span>現在の順位と24時間の変化を確認する</span></a>
        <a href="/games/playstation/#ps5-ranking"><strong>PS5ランキング</strong><span>現在のPS5順位を確認する</span></a>
        <a href="/games/playstation/#ps4-ranking"><strong>PS4ランキング</strong><span>現在のPS4順位を確認する</span></a>
      </div>
    </section>

    <aside class="notice">
      <strong>比較方法</strong>
      <p>{week.dataDisclosure} このページは週の確定時点の記録です。現在価格・在庫は販売ページでご確認ください。</p>
    </aside>
  </article>
</BaseLayout>
