---
import "../styles/global.css";
import "../styles/overrides.css";
import { siteConfig } from "../config";
import WatchlistScript from "../components/WatchlistScript.astro";

interface Props {
  title?: string;
  description?: string;
  structuredData?: Record<string, any> | Record<string, any>[];
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  structuredData = [],
  ogType = "website",
  publishedTime,
  modifiedTime
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
const schemas = Array.isArray(structuredData) ? structuredData : [structuredData];
const globalSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": new URL("/#organization", Astro.site).toString(),
    name: siteConfig.name,
    url: new URL("/", Astro.site).toString(),
    logo: new URL("/brand/icon.png", Astro.site).toString(),
    sameAs: siteConfig.xUrl ? [siteConfig.xUrl] : undefined
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": new URL("/#website", Astro.site).toString(),
    name: siteConfig.name,
    url: new URL("/", Astro.site).toString(),
    inLanguage: "ja",
    publisher: { "@id": new URL("/#organization", Astro.site).toString() }
  }
];
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="18bkD956Gj3a_2GBjRWH7bKFoSrDXwbM0oE8xLWH1KE" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/brand/icon.png" type="image/png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL("/brand/header.png", Astro.site)} />
    <meta property="og:image:alt" content="モノ上昇便" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content="ja_JP" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/brand/header.png", Astro.site)} />
    {[...globalSchemas, ...schemas].filter(Boolean).map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <img src="/brand/icon.png" alt="" width="52" height="52" />
        <span>モノ<span class="accent">上昇</span>便</span>
      </a>
      <nav aria-label="メインナビゲーション">
        <a class:list={{ active: currentPath === "/" || currentPath === "/games/" }} href="/games/">ゲーム総合</a>
        <a class:list={{ active: currentPath === "/games/switch/" }} href="/games/switch/">Switch</a>
        <a class:list={{ active: currentPath === "/games/playstation/" }} href="/games/playstation/#ps5-ranking">PS5</a>
        <a class:list={{ active: currentPath === "/games/playstation/" }} href="/games/playstation/#ps4-ranking">PS4</a>
        <a class:list={{ active: currentPath.startsWith("/categories/") }} href="/categories/stationery/">文具</a>
        <a class:list={{ active: currentPath.startsWith("/articles/") }} href="/articles/">記事一覧</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer>
      <p class="ad-disclosure">当サイトはアフィリエイト広告を利用しています</p>
      <!-- Rakuten Web Services Attribution Snippet FROM HERE -->
      <a href="https://developers.rakuten.com/" target="_blank" rel="noopener">Supported by Rakuten Developers</a>
      <!-- Rakuten Web Services Attribution Snippet TO HERE -->
      <div class="footer-links">
        <a href="/about/">運営情報</a>
        <a href="/privacy/">プライバシーポリシー</a>
        <a href="/contact/">お問い合わせ</a>
      </div>
      <small>© 2026 モノ上昇便</small>
    </footer>
    <WatchlistScript />
  </body>
</html>
