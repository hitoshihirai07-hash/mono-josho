---
import "../styles/admin.css";

interface Props {
  title?: string;
  active?: "home" | "x-post";
}

const { title = "管理画面", active = "home" } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <meta name="referrer" content="no-referrer" />
    <link rel="icon" href="/brand/icon.png" type="image/png" />
    <title>{title}</title>
  </head>
  <body>
    <header class="admin-header">
      <a class="admin-brand" href="/admin/">
        <img src="/brand/icon.png" alt="" width="38" height="38" />
        <span>モノ上昇便</span>
      </a>
      <nav class="admin-nav" aria-label="管理メニュー">
        <a href="/admin/" class:list={{ "is-active": active === "home" }}>管理トップ</a>
        <a href="/admin/x-post/" class:list={{ "is-active": active === "x-post" }}>X投稿</a>
      </nav>
    </header>
    <main><slot /></main>
  </body>
</html>
